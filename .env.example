# ── GitHub provider ───────────────────────────────────────────────────────────
# Personal Access Token với scope: repo
# Tạo tại: https://github.com/settings/tokens
GH_TOKEN=
GH_OWNER=your-github-username

# ── GitLab provider ───────────────────────────────────────────────────────────
# Numeric Project ID — tìm tại Project → Settings → General → Project ID
GITLAB_PROJECT_ID=
# Personal Access Token với scopes: api, write_registry
# Tạo tại: GitLab → User Settings → Access Tokens
GITLAB_TOKEN=
# Chỉ cần nếu dùng self-hosted GitLab (mặc định https://gitlab.com)
# GITLAB_BASE_URL=https://gitlab.yourcompany.com
